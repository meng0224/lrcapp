<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    tools:context=".MainActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="12dp"
            android:paddingEnd="20dp"
            android:paddingBottom="28dp">

            <LinearLayout
                android:id="@+id/headerCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_main_header_tonal"
                android:orientation="vertical"
                android:paddingStart="8dp"
                android:paddingTop="4dp"
                android:paddingEnd="8dp"
                android:paddingBottom="28dp">

                <com.google.android.material.appbar.MaterialToolbar
                    android:id="@+id/toolbar"
                    style="@style/Widget.LrcApp.Toolbar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="56dp" />

                <TextView
                    android:id="@+id/tvHeroTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:text="@string/main_toolbar_title"
                    android:textAppearance="@style/TextAppearance.LrcApp.DisplayLarge" />

                <TextView
                    android:id="@+id/tvHeroSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/main_toolbar_subtitle"
                    android:textAppearance="@style/TextAppearance.LrcApp.SupportingText" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/formatCard"
                style="@style/Widget.LrcApp.Card.Feature"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/tvEmptyOutputFormat"
                        style="@style/Widget.LrcApp.Chip.Status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/output_format"
                        android:textColor="?attr/colorOnPrimaryContainer"
                        app:chipBackgroundColor="?attr/colorPrimaryContainer" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/supported_formats"
                        android:textAppearance="@style/TextAppearance.LrcApp.PanelHeadline" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/format_explainer_title"
                        android:textAppearance="@style/TextAppearance.LrcApp.SupportingText"
                        android:textColor="?attr/colorOnPrimaryContainer" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/storageCard"
                style="@style/Widget.LrcApp.Card.Section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/storage_section_title"
                                android:textAppearance="@style/TextAppearance.LrcApp.TitleMedium" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/main_toolbar_subtitle"
                                android:textAppearance="@style/TextAppearance.LrcApp.MetaLabel" />
                        </LinearLayout>

                        <com.google.android.material.chip.Chip
                            android:id="@+id/tvStorageModeChip"
                            style="@style/Widget.LrcApp.Chip.Status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/storage_mode_chip_default"
                            android:textColor="@color/status_pending_onContainer"
                            app:chipBackgroundColor="@color/status_pending_container"
                            app:chipStrokeWidth="0dp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvOutputDir"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="@string/storage_mode_default"
                        android:textAppearance="@style/TextAppearance.LrcApp.HeadlineSmall" />

                    <TextView
                        android:id="@+id/tvOutputDirHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="/storage/emulated/0/Download"
                        android:textAppearance="@style/TextAppearance.LrcApp.SupportingText" />

                    <LinearLayout
                        android:id="@+id/layoutCustomOutputActions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSelectOutputDir"
                            style="@style/Widget.LrcApp.Button.SecondaryTonal"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="10dp"
                            android:layout_weight="1"
                            android:text="@string/select_directory" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnClearOutputDir"
                            style="@style/Widget.LrcApp.Button.InlineText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/clear_directory" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/sourceOutputPanel"
                        style="@style/Widget.LrcApp.Panel.Row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/storage_mode_source"
                                android:textAppearance="@style/TextAppearance.LrcApp.TitleSmall"
                                android:textColor="?attr/colorOnSurface" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="@string/storage_source_hint"
                                android:textAppearance="@style/TextAppearance.LrcApp.SupportingText" />
                        </LinearLayout>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switchOutputToSourceDirectory"
                            style="@style/Widget.LrcApp.Switch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/recursiveImportPanel"
                        style="@style/Widget.LrcApp.Panel.Row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/recursive_import_title"
                                android:textAppearance="@style/TextAppearance.LrcApp.TitleSmall"
                                android:textColor="?attr/colorOnSurface" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="@string/recursive_import_hint"
                                android:textAppearance="@style/TextAppearance.LrcApp.SupportingText" />
                        </LinearLayout>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switchRecursiveImport"
                            style="@style/Widget.LrcApp.Switch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/actionCard"
                style="@style/Widget.LrcApp.Card.Action"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvFileListTitle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/file_list_title"
                                android:textAppearance="@style/TextAppearance.LrcApp.TitleMedium" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/main_toolbar_subtitle"
                                android:textAppearance="@style/TextAppearance.LrcApp.MetaLabel" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvFileSummary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textAppearance="@style/TextAppearance.LrcApp.LabelMedium" />
                    </LinearLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/authBannerCard"
                        style="@style/Widget.LrcApp.Card.Warning"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <TextView
                                android:id="@+id/tvAuthBannerTitle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/auth_banner_title"
                                android:textAppearance="@style/TextAppearance.LrcApp.TitleMedium"
                                android:textColor="@color/warning_onContainer" />

                            <TextView
                                android:id="@+id/tvAuthBannerMessage"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="@string/auth_banner_message"
                                android:textAppearance="@style/TextAppearance.LrcApp.BodyMedium"
                                android:textColor="@color/warning_onContainer" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnAuthorizeSourceDir"
                                style="@style/Widget.LrcApp.Button.Filled"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="16dp"
                                android:text="@string/authorize_directory" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/progressCard"
                        style="@style/Widget.LrcApp.Card.Emphasis"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="@string/progress_section_title"
                                        android:textAppearance="@style/TextAppearance.LrcApp.PanelHeadline" />

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:text="@string/progress_placeholder"
                                        android:textAppearance="@style/TextAppearance.LrcApp.MetaLabel"
                                        android:textColor="?attr/colorOnPrimaryContainer" />
                                </LinearLayout>

                                <TextView
                                    android:id="@+id/tvProgressCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0/0"
                                    android:textAppearance="@style/TextAppearance.LrcApp.TitleMedium"
                                    android:textColor="?attr/colorOnPrimaryContainer" />
                            </LinearLayout>

                            <com.google.android.material.progressindicator.LinearProgressIndicator
                                android:id="@+id/progressBar"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="16dp"
                                android:max="100"
                                android:progress="0"
                                app:indicatorColor="?attr/colorPrimary"
                                app:trackColor="@color/md_theme_light_surfaceContainerHigh" />

                            <TextView
                                android:id="@+id/tvProgress"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:text="@string/progress_placeholder"
                                android:textAppearance="@style/TextAppearance.LrcApp.SupportingText"
                                android:textColor="?attr/colorOnPrimaryContainer" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:id="@+id/emptyStateContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:orientation="vertical">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/emptyStateHeroCard"
                            style="@style/Widget.LrcApp.Card.EmptyState"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_horizontal"
                                android:orientation="vertical"
                                android:paddingStart="24dp"
                                android:paddingTop="30dp"
                                android:paddingEnd="24dp"
                                android:paddingBottom="30dp">

                                <TextView
                                    android:id="@+id/tvEmptyStateBadge"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/empty_state_icon_background"
                                    android:paddingStart="18dp"
                                    android:paddingTop="10dp"
                                    android:paddingEnd="18dp"
                                    android:paddingBottom="10dp"
                                    android:text="@string/empty_state_badge"
                                    android:textAppearance="@style/TextAppearance.LrcApp.TitleMedium"
                                    android:textColor="?attr/colorOnPrimaryContainer" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="20dp"
                                    android:gravity="center"
                                    android:text="@string/empty_state_title"
                                    android:textAppearance="@style/TextAppearance.LrcApp.PanelHeadline" />

                                <TextView
                                    android:id="@+id/tvEmptyFormats"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="12dp"
                                    android:gravity="center"
                                    android:text="@string/supported_formats"
                                    android:textAppearance="@style/TextAppearance.LrcApp.SupportingText"
                                    android:textColor="?attr/colorOnPrimaryContainer" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/fileListCard"
                        style="@style/Widget.LrcApp.Card.Subsection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:visibility="gone">

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recyclerView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:clipToPadding="false"
                            android:nestedScrollingEnabled="false"
                            android:padding="12dp" />
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnConvert"
                        style="@style/Widget.LrcApp.Button.PrimaryCtaFilled"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="@string/select_files" />

                    <LinearLayout
                        android:id="@+id/secondaryActionsRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSelectFiles"
                            style="@style/Widget.LrcApp.Button.SecondaryTonal"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="10dp"
                            android:layout_weight="1"
                            android:text="@string/reselect_files" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnClearFileList"
                            style="@style/Widget.LrcApp.Button.InlineText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/clear_file_list" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
